# --- TARGET WEBSITES ---

# 1. Paribu Cineverse Configuration
# Leave blank to disable checking Paribu Cineverse
PARIBU_URL=https://www.paribucineverse.com/fantastik-filmleri/orumcek-adam-yepyeni-bir-gun-filmi-izle

# 2. Biletinial Configuration
# Leave blank to disable checking Biletinial
BILETINIAL_URL=https://biletinial.com/tr-tr/sinema
# Comma-separated list of keywords to search case-insensitively on Biletinial page
BILETINIAL_KEYWORDS=spider,örümcek,orumcek


# --- COMMON CONFIGURATIONS ---
CHECK_INTERVAL_SECONDS=300
STATE_FILE_PATH=state.json
LOG_FILE_PATH=monitor.log


# --- NOTIFICATION CHANNELS ---
# Configure at least one of the following:

# 1. ntfy.sh (Recommended for phone ring / alarm sound notifications)
# Open ntfy mobile app, subscribe to this unique topic name
NTFY_TOPIC=paribu_spider_man_tickets_91823
NTFY_SERVER=https://ntfy.sh

# 2. Telegram Bot (Alternative)
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# TELEGRAM_CHAT_ID=987654321
